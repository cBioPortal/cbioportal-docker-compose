DOCKER_IMAGE_CBIOPORTAL=cbioportal/cbioportal-dev:994d7a95c648712b1077dfeb480475af49b37bc7-web-shenandoah
DOCKER_IMAGE_SESSION_SERVICE=cbioportal/session-service:0.6.4
DOCKER_IMAGE_CLICKHOUSE=clickhouse/clickhouse-server:24.10
# Uncomment to pull a pre-built importer image from Docker Hub instead of building locally.
# Run `docker compose pull cbioportal-clickhouse-importer` after setting this.
# DOCKER_IMAGE_IMPORTER=cbioportal/clickhouse-importer:latest

# ClickHouse
CLICKHOUSE_DB=cbioportal
CLICKHOUSE_USER=cbio_user
CLICKHOUSE_PASSWORD=somepassword
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HOST=cbioportal-clickhouse-database
CLICKHOUSE_PORT=9000
DB_CLICKHOUSE_URL=jdbc:ch://cbioportal-clickhouse-database:8123/cbioportal

# cBioPortal
SHOW_DEBUG_INFO=true
PORTAL_HOME=/cbioportal-webapp
APP_CLICKHOUSE_MODE=true
APP_SPRING_PROFILE=clickhouse

# Importer
IMPORTER_PROPERTIES_FILEPATH=/opt/application.properties

# Session service
SERVER_PORT=5001
SESSION_SERVICE_JAVA_OPTS=-Dspring.data.mongodb.uri=mongodb://cbioportal-session-database:27017/session-service
MONGO_INITDB_DATABASE=session_service

# Import
APP_CBIOPORTAL_CORE_BRANCH=rfc100-docs
DATAHUB_STUDIES=lgg_ucsf_2014 msk_impact_2017
